# Copy this file to .env and fill in your real values.
# Never commit .env.

# MongoDB Atlas
MONGODB_URI=mongodb+srv://abdelrahman:abd123@cluster0.ucmkocy.mongodb.net/?appName=Cluster0/?appName=Cluster0
MONGODB_DATABASE=sample_airbnb
MONGODB_COLLECTION=listingsAndReviews

# HDFS output paths
AIRBNB_RAW_PATH=hdfs://namenode:9000/data/airbnb/raw/listingsAndReviews
AIRBNB_INGEST_DATE=
AIRBNB_RAW_FULL_REFRESH=false
AIRBNB_CLEAN_PATH=hdfs://namenode:9000/data/airbnb/clean/listings
AIRBNB_ANALYTICS_PATH=hdfs://namenode:9000/data/airbnb/analytics/market_room_type_summary

# Spark sizing for this local Docker environment
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2
SPARK_OUTPUT_PARTITIONS=4
SPARK_SQL_SHUFFLE_PARTITIONS=8
MONGO_SPARK_CONNECTOR_PACKAGE=org.mongodb.spark:mongo-spark-connector_2.12:10.2.2
