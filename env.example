# ============================================================
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to Git — it's in .gitignore.
# ============================================================

# --- MongoDB Atlas ---
MONGO_ATLAS_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_ATLAS_DB=sample_airbnb
MONGO_ATLAS_COLLECTION=listingsAndReviews

# --- Hive Metastore DB ---
HIVE_METASTORE_DB_PASSWORD=hive_password

# --- Airbyte DB ---
AIRBYTE_DB_PASSWORD=airbyte_password

# --- Spark ---
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2
